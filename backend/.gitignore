
# Test coverage reports
/coverage/

# Active Storage local disk service — user-uploaded blobs in development.
/storage/*
!/storage/.keep

# Ignore the tmp directory and all its subdirectories, keeping placeholders.
/tmp/*
!/tmp/.keep
!/tmp/pids/
/tmp/pids/*
!/tmp/pids/.keep
!/tmp/storage/
/tmp/storage/*
!/tmp/storage/.keep
