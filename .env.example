# Copy to .env and adjust if needed: cp .env.example .env
# docker-compose reads .env from the project root automatically.

# PostgreSQL
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=app_development
# Host port exposed for Postgres (avoid clashing with a local Postgres on 5432)
DATABASE_HOST_PORT=5432

# Frontend origin used for backend CORS
FRONTEND_ORIGIN=http://localhost:5173
